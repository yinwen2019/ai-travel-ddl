# Perplexity API Key (for AI data update script)
PERPLEXITY_API_KEY=your_api_key_here

# Optional: OpenAI compatible API
# OPENAI_API_KEY=your_api_key_here
# AI_API_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# Optional: DeepSeek（OpenAI 兼容）
# 注意：DeepSeek 模型本身不自带联网搜索，对本管线（需查询未来会议 DDL/地点）可靠性较低，
# 建议优先用 Perplexity（自带联网）。V4 模型 id：deepseek-v4-pro / deepseek-v4-flash。
# OPENAI_API_KEY=sk-your_deepseek_key_here
# AI_API_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-v4-pro

# Tavily（搜索接地）— 使用 DeepSeek/OpenAI 等无联网能力的模型时必填，
# 为模型提供真实网页上下文。注册：https://app.tavily.com（免费档约 1000 次/月）。
# Perplexity 自带联网，无需配置此项。
TAVILY_API_KEY=your_tavily_key_here

